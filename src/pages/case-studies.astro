---
import Base from '../layouts/Base.astro';

const cases = [
  {
    tag: 'Virtualization · Enterprise',
    title: 'VMware vSphere Modernization for Regional Financial Institution',
    summary: 'A regional bank running aging ESXi 6.0 infrastructure needed to modernize their virtualization platform to meet new compliance requirements while maintaining zero-downtime operations across 200+ VMs.',
    challenge: 'The client was running an end-of-life VMware vSphere 6.0 environment across three physical sites. The aging infrastructure posed compliance risks, performance bottlenecks, and a complete absence of DR capability. Any migration had to maintain 99.99% uptime for core banking applications.',
    approach: 'Nuvextro designed a phased migration strategy with a new vSphere 8.0 cluster built in parallel. Workloads were live-migrated using vMotion in carefully planned maintenance windows. NSX-T was introduced to modernize the network layer, and a Veeam-based replication strategy was implemented for DR.',
    outcome: 'Full infrastructure modernization completed across 12 weeks with zero unplanned downtime. The client achieved full compliance with updated banking IT regulations, a 40% reduction in infrastructure footprint through improved VM density, and a functional DR capability with a 4-hour RTO.',
    metrics: [
      { value: '12 wks', label: 'Delivery time' },
      { value: '0', label: 'Unplanned downtime events' },
      { value: '40%', label: 'Infrastructure footprint reduction' },
    ],
  },
  {
    tag: 'Cloud Migration · Manufacturing',
    title: 'AWS Cloud Migration for Mid-Market Manufacturing Company',
    summary: 'A 400-person manufacturing business needed to migrate 18 on-premises workloads to AWS to enable remote operations and reduce data center costs ahead of a facility consolidation.',
    challenge: 'The client had a mix of legacy Windows Server applications, SQL Server databases, and a custom ERP system — many of which had undocumented dependencies. The migration had to be completed within 3 months to align with the physical data center decommission schedule.',
    approach: 'Nuvextro conducted a full application dependency mapping exercise using AWS Application Discovery Service. Workloads were grouped into migration waves by dependency and business criticality. A landing zone was built using AWS Control Tower with cost guardrails and security baselines. Migration was executed using AWS MGN and DMS for databases.',
    outcome: 'All 18 workloads migrated successfully within the 10-week target. Monthly infrastructure costs reduced by $8,200 vs the on-premises equivalent. Post-migration, Nuvextro implemented a cost optimization review that identified a further $1,400/month in savings through rightsizing and reserved instance planning.',
    metrics: [
      { value: '18', label: 'Workloads migrated' },
      { value: '10 wks', label: 'End-to-end delivery' },
      { value: '$8.2k', label: 'Monthly cost reduction' },
    ],
  },
  {
    tag: 'Disaster Recovery · Healthcare',
    title: 'Disaster Recovery Solution for Healthcare Services Provider',
    summary: 'A healthcare organization needed a documented, tested disaster recovery capability for their patient data and clinical systems — a compliance requirement they had not previously met.',
    challenge: 'The client operated critical patient management and imaging systems with no formal DR plan. An upcoming audit required evidence of a documented recovery capability with defined RTO/RPO targets. Budget constraints ruled out a traditional secondary data center.',
    approach: 'Nuvextro designed a cloud-based DR solution using Azure Site Recovery for primary clinical systems, with Veeam Cloud Connect for secondary backup targets. Recovery objectives were defined collaboratively with clinical IT leadership: 4-hour RTO and 1-hour RPO for critical systems. Full runbooks were developed, and a tabletop DR exercise was conducted with the client team.',
    outcome: 'The client passed their compliance audit with the required DR documentation and evidence of a successful test recovery. Ongoing monthly DR testing is managed by Nuvextro as part of a retainer engagement. Total solution cost was under $3,000 to implement, with monthly operational costs of $620.',
    metrics: [
      { value: '4hr', label: 'Recovery time objective' },
      { value: '1hr', label: 'Recovery point objective' },
      { value: '$620/mo', label: 'Ongoing operational cost' },
    ],
  },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Case Studies — Nuvextro" description="Real-world infrastructure and cloud project case studies delivered by Nuvextro's expert team.">

  <!-- HERO -->
  <section class="hero" style={`background-image: url('${base}/img/case-studies-hero.png'); background-size: cover; background-position: center; position: relative; padding: 10rem 0 6rem; min-height: auto;`}>
    <div class="hero-overlay" style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(10, 25, 47, 0.8), rgba(10, 25, 47, 0.4));"></div>
    <div class="container hero-content" style="position: relative; z-index: 1;">
      <div class="hero-eyebrow animate delay-1">
        <span class="label" style="color: var(--brand-blue); border-color: var(--brand-blue-pale);">Our Work</span>
      </div>
      <h1 class="hero-title animate delay-2" style="font-size: clamp(2.2rem, 5vw, 3.8rem); line-height: 1.1; color: #ffffff;">
        Projects that delivered<br/>measurable outcomes
      </h1>
      <p class="hero-sub animate delay-3" style="color: rgba(255,255,255,0.9); max-width: 600px;">
        A selection of infrastructure and cloud projects delivered through Nuvextro's expert team. Client details anonymized where requested.
      </p>
    </div>
  </section>

  <section style="padding:0 0 6rem;">
    <div class="container">
      <div style="display:flex; flex-direction:column; gap:3rem;">
        {cases.map(c => (
          <article class="card" style="padding:2.5rem;">
            <div class="cs-tag">{c.tag}</div>
            <h2 style="font-size:clamp(1.2rem,2.5vw,1.6rem); font-weight:700; margin-bottom:1rem; line-height:1.3;">{c.title}</h2>
            <p style="color:var(--white-dim); font-size:0.95rem; line-height:1.7; margin-bottom:2rem;">{c.summary}</p>

            <!-- Metrics -->
            <div style="display:flex; gap:2rem; margin-bottom:2rem; flex-wrap:wrap;">
              {c.metrics.map(m => (
                <div style="border-left:2px solid var(--brand-blue); padding-left:1rem;">
                  <div style="font-size:1.5rem; font-weight:800; color:var(--brand-blue);">{m.value}</div>
                  <div style="font-size:0.75rem; color:var(--white-muted); font-family:'Open Sans', sans-serif; letter-spacing:0.06em;">{m.label}</div>
                </div>
              ))}
            </div>

            <div class="cs-details-grid">
              <div>
                <div style="font-size:0.72rem; font-family:'Open Sans', sans-serif; letter-spacing:0.1em; color:var(--brand-blue); text-transform:uppercase; margin-bottom:0.5rem;">Challenge/Approach/Outcome</div>
                <p style="font-size:0.86rem; color:var(--white-dim); line-height:1.65;">{c.challenge}</p>
              </div>
              <div>
                <div style="font-size:0.72rem; font-family:'DM Mono',monospace; letter-spacing:0.1em; color:var(--brand-blue); text-transform:uppercase; margin-bottom:0.5rem;">Approach</div>
                <p style="font-size:0.86rem; color:var(--white-dim); line-height:1.65;">{c.approach}</p>
              </div>
              <div>
                <div style="font-size:0.72rem; font-family:'DM Mono',monospace; letter-spacing:0.1em; color:var(--brand-blue); text-transform:uppercase; margin-bottom:0.5rem;">Outcome</div>
                <p style="font-size:0.86rem; color:var(--white-dim); line-height:1.65;">{c.outcome}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA -->
      <div style="margin-top:4rem; text-align:center;">
        <p style="color:var(--white-dim); margin-bottom:1.5rem;">Have a project that needs this kind of expertise?</p>
        <a href={`${base}/contact`} class="btn-primary">Request a Quote →</a>
      </div>
    </div>
  </section>

  <style>
    .cs-details-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 769px) {
      .cs-details-grid {
        grid-template-columns: 1fr 1fr 1fr;
      }
    }
  </style>
</Base>
