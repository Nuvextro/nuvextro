---
import Base from '../layouts/Base.astro';
import { CheckCircle2 } from 'lucide-astro';
---

<Base title="Thank You — Nuvextro">
  <div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding-top:68px;">
    <div style="text-align:center; max-width:520px; padding:2rem; position:relative; z-index:1;">
      <div style="width:64px; height:64px; background:var(--brand-blue-pale); border:1px solid var(--border-hi); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; color:var(--brand-blue);"><CheckCircle2 size={32} /></div>
      <span class="label">Message received</span>
      <h1 style="font-size:2.5rem; font-weight:800; letter-spacing:-0.025em; margin:0.75rem 0 1rem;">Thank you for reaching out</h1>
      <p style="color:var(--white-dim); line-height:1.7; margin-bottom:2.5rem;">
        We've received your message and will be in touch within 1–2 business days. In the meantime, feel free to explore our services and case studies.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href={`${import.meta.env.BASE_URL}`} class="btn-primary">Back to Home →</a>
        <a href={`${import.meta.env.BASE_URL}services`} class="btn-outline">Explore Services</a>
      </div>
    </div>
  </div>
</Base>
