---
import Base from '../layouts/Base.astro';
import { 
  Server, Cloud, Activity, Shield, Database, Wrench,
  FileText, PenTool, CheckCircle, Handshake
} from 'lucide-astro';

const services = [
  { icon: Server, title: 'Managed IT Infrastructure', desc: 'Secure and high-performing enterprise infrastructure managed by our expert team.' },
  { icon: Cloud, title: 'Cloud Infrastructure Management', desc: 'Design, optimize, and manage scalable cloud environments across AWS, Azure, and hybrid platforms.' },
  { icon: Activity, title: 'Network Monitoring & Optimization', desc: 'Proactive management and optimization of enterprise network environments for maximum uptime.' },
  { icon: Shield, title: 'Cybersecurity & Risk Management', desc: 'Comprehensive security frameworks, monitoring, and threat response to protect your systems.' },
  { icon: Database, title: 'Backup & Disaster Recovery', desc: 'Reliable business continuity planning and automated recovery strategies for critical data.' },
  { icon: Wrench, title: 'IT Support & Operations', desc: 'Professional technical support and operational stability for your enterprise systems.' },
];

const steps = [
  { n: '01', icon: FileText, title: 'Assess', desc: 'We begin by understanding your current infrastructure, performance challenges, and business goals.' },
  { n: '02', icon: PenTool, title: 'Design', desc: 'Our experts create a tailored infrastructure strategy and architecture aligned with your objectives.' },
  { n: '03', icon: CheckCircle, title: 'Implement', desc: 'We deploy solutions with precision, minimal disruption, and enterprise-grade quality standards.' },
  { n: '04', icon: Handshake, title: 'Optimize', desc: 'We ensure continuous performance, cost efficiency, and security through proactive management.' },
];
---

<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container hero-content">
      <div class="hero-eyebrow animate delay-1">
        <span class="label">Engineering Technology for Tomorrow</span>
      </div>
      <h1 class="hero-title animate delay-2">
        Enterprise <em>Infrastructure & Cloud Consulting</em> That Scales With You
      </h1>
      <p class="hero-sub animate delay-3">
        Nuvextro delivers scalable, secure, and reliable IT infrastructure solutions. We help businesses design, manage, and optimize systems for performance and cost efficiency.
      </p>

      <div class="hero-actions animate delay-4">
        <a href="/contact" class="btn-primary">Get a Free Consultation &rarr;</a>
        <a href="/services" class="btn-outline">Explore Services</a>
      </div>

      <div class="hero-stats animate delay-4">
        <div class="hero-stat-item">
          <div class="hero-stat-num">6+</div>
          <div class="hero-stat-label">Core service areas</div>
        </div>
        <div class="hero-stat-item">
          <div class="hero-stat-num">100%</div>
          <div class="hero-stat-label">Enterprise-grade delivery</div>
        </div>
        <div class="hero-stat-item">
          <div class="hero-stat-num">Cloud-First</div>
          <div class="hero-stat-label">Modern architecture</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section style="padding: 6rem 0;">
    <div class="container">
      <div class="section-header">
        <span class="label">What We Do</span>
        <h2 class="section-title" style="margin-top:0.75rem;">Managed services built<br/>for enterprise scale</h2>
        <p class="section-sub">From strategic consulting to ongoing infrastructure management, Nuvextro provides the expertise your organization needs.</p>
      </div>
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px,1fr)); gap:1.5rem;">
        {services.map(s => (
          <div class="card">
            <div class="service-icon"><s.icon size={24} /></div>
            <div class="service-title">{s.title}</div>
            <p class="service-desc">{s.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/services" class="btn-outline">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="padding: 6rem 0; background: linear-gradient(180deg, transparent, var(--brand-blue-pale) 50%, transparent);">
    <div class="container">
      <div class="section-header">
        <span class="label">Our Approach</span>
        <h2 class="section-title" style="margin-top:0.75rem;">A structured process<br/>for measurable results</h2>
        <p class="section-sub">Nuvextro follows a proven methodology to ensure your infrastructure is resilient, efficient, and future-ready.</p>
      </div>
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap:1.5rem;">
        {steps.map(s => (
          <div class="card" style="border-top: 2px solid var(--brand-blue); border-radius: 0 0 8px 8px;">
            <div class="step-num">Phase {s.n}</div>
            <div style="color:var(--brand-blue); margin-bottom:1rem;"><s.icon size={32} /></div>
            <div class="step-title">{s.title}</div>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section style="padding: 6rem 0;">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
        <div>
          <span class="label">Why Nuvextro</span>
          <h2 style="font-size:clamp(1.8rem,3vw,2.5rem); font-weight:800; letter-spacing:-0.025em; margin:0.75rem 0 1.5rem;">
            Reliable, Scalable, and<br/>Security-First Solutions
          </h2>
          <div class="divider"></div>
          <div class="prose">
            <p>Modern businesses require infrastructure that can handle dynamic growth while maintaining strict security and performance standards. Nuvextro bridges the gap between complex technology and business outcomes.</p>
            <p>We provide deep technical expertise and structured governance, ensuring your systems are optimized for cost and reliability so you can focus on your core operations.</p>
          </div>
          <div style="margin-top:2rem;">
            <a href="/about" class="btn-outline">Learn More About Us →</a>
          </div>
        </div>
        <div style="display:flex; flex-direction:column; gap:1rem;">
          {[
            ['Enterprise Expertise', 'Deep experience managing complex IT environments across diverse industries.'],
            ['Scalable by Design', 'We build infrastructure that grows with you without constant reconfiguration.'],
            ['Cost Optimization', 'Reduce operational overhead and optimize cloud spending with smarter architecture.'],
            ['Reliability & Uptime', 'Proactive monitoring and failover systems ensuring high system availability.'],
          ].map(([t,d]) => (
            <div class="highlight-box" style="display:flex; gap:1rem; align-items:flex-start;">
              <div style="color:var(--brand-blue); font-size:1rem; margin-top:2px;">◆</div>
              <div>
                <div style="font-weight:700; font-size:0.95rem; margin-bottom:0.25rem;">{t}</div>
                <div style="font-size:0.88rem; color:var(--white-dim);">{d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="padding: 5rem 0;">
    <div class="container">
      <div style="background: linear-gradient(135deg, var(--navy-3), var(--navy-4)); border: 1px solid var(--border-hi); border-radius:12px; padding:4rem; text-align:center; position:relative; overflow:hidden;">
        <div style="position:absolute; inset:0; background:radial-gradient(ellipse at center, var(--brand-blue-pale) 0%, transparent 70%); pointer-events:none;"></div>
        <span class="label" style="position:relative;">Ready to optimize?</span>
        <h2 style="font-size:clamp(1.8rem,3vw,2.6rem); font-weight:800; letter-spacing:-0.025em; margin:0.75rem 0 1rem; position:relative;">
          Let's talk about your infrastructure needs
        </h2>
        <p style="color:var(--white-dim); max-width:480px; margin:0 auto 2rem; line-height:1.7; position:relative;">
          Whether it's an ongoing managed service or a specific cloud modernization project — we design and deliver solutions that work.
        </p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; position:relative;">
          <a href="/contact" class="btn-primary">Get a Free Consultation →</a>
          <a href="/services" class="btn-outline">View All Services</a>
        </div>
      </div>
    </div>
  </section>

</Base>
