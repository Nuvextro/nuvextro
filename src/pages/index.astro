---
import Base from '../layouts/Base.astro';
import { 
  Server, Cloud, Activity, Shield, Database, Wrench,
  FileText, PenTool, CheckCircle, Handshake,
  Zap, Network, BarChart3, Users, ArrowRight
} from 'lucide-astro';

const services = [
  { icon: Server, title: 'Managed IT Infrastructure', desc: 'Secure and high-performing enterprise infrastructure managed by our expert team.' },
  { icon: Cloud, title: 'Cloud Infrastructure Management', desc: 'Design, optimize, and manage scalable cloud environments across AWS, Azure, and hybrid platforms.' },
  { icon: Activity, title: 'Network Monitoring & Optimization', desc: 'Proactive management and optimization of enterprise network environments for maximum uptime.' },
  { icon: Shield, title: 'Cybersecurity & Risk Management', desc: 'Comprehensive security frameworks, monitoring, and threat response to protect your systems.' },
  { icon: Database, title: 'Backup & Disaster Recovery', desc: 'Reliable business continuity planning and automated recovery strategies for critical data.' },
  { icon: Wrench, title: 'IT Support & Operations', desc: 'Professional technical support and operational stability for your enterprise systems.' },
];

const steps = [
  { n: '01', icon: FileText, title: 'Assess', desc: 'We begin by understanding your current infrastructure, performance challenges, and business goals.' },
  { n: '02', icon: PenTool, title: 'Design', desc: 'Our experts create a tailored infrastructure strategy and architecture aligned with your objectives.' },
  { n: '03', icon: CheckCircle, title: 'Implement', desc: 'We deploy solutions with precision, minimal disruption, and enterprise-grade quality standards.' },
  { n: '04', icon: Handshake, title: 'Optimize', desc: 'We ensure continuous performance, cost efficiency, and security through proactive management.' },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base>
  <!-- HERO -->
  <section class="hero" style={`background-image: url('${base}/img/home-hero-1.webp'); background-size: cover; background-position: center; position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 6rem 0;`}>
    <div class="hero-overlay" style="position: absolute; inset: 0; background: rgba(10, 25, 47, 0.15);"></div>
    <div class="container hero-content" style="position: relative; z-index: 1; display: flex; justify-content: center;">
      <div class="glass-box animate-fade-in" style="max-width: 1000px; text-align: center;">
        <div class="hero-eyebrow animate delay-1">
          <span class="label" style="color: var(--brand-blue); border-color: rgba(27, 168, 250, 0.3); background: rgba(27, 168, 250, 0.05);">Enterprise Infrastructure Mastery</span>
        </div>
        <h1 class="hero-title animate delay-2" style="font-size: clamp(2.2rem, 4.2vw, 3.2rem); line-height: 1.1; color: #ffffff; margin-bottom: 1.5rem;">
          Enterprise <span style="color: var(--brand-blue);">IT Infrastructure</span><br/>That Scales With Your Business
        </h1>
        <p class="hero-sub animate delay-3" style="color: rgba(255,255,255,0.9); max-width: 750px; margin: 0 auto 2.5rem; font-size: 1.05rem; line-height: 1.7;">
          Design, manage, and optimize secure, scalable IT systems. Cloud, security, networking, and disaster recovery solutions built for reliability and performance.
        </p>
   
        <div class="hero-actions animate delay-4" style="justify-content: center; margin-bottom: 0;">
          <a href={`${base}/contact`} class="btn-primary" style="padding: 1rem 2.8rem;">Book Consultation &rarr;</a>
          <a href={`${base}/services`} class="btn-outline" style="border-color: rgba(255,255,255,0.3); color: #ffffff; padding: 1rem 2.5rem;">Explore Services</a>
        </div>

        <div class="hero-footer-stats animate delay-5">
          <div class="hero-stat-item">
            <span class="hero-stat-val">15+ Years</span>
            <span class="hero-stat-lbl">Expertise</span>
          </div>
          <div class="hero-stat-item">
            <span class="hero-stat-val">24/7 Ops</span>
            <span class="hero-stat-lbl">Monitoring</span>
          </div>
          <div class="hero-stat-item">
            <span class="hero-stat-val">Managed Sec</span>
            <span class="hero-stat-lbl">Built-in</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE NUVEEXTRO (from v2) - MOVED UP -->
  <section class="first-section" style="padding-bottom: 6.5rem; background: var(--navy);">
    <div class="container">
      <div class="section-header" style="text-align: center; max-width: 800px; margin: 0 auto 4.5rem;">
        <h2 class="section-title">Why Choose Nuvextro</h2>
        <p class="section-sub">We combine deep technical expertise with a results-driven approach to deliver IT infrastructure solutions that work.</p>
      </div>
      
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px,1fr)); gap:2.5rem;">
        {[
          { icon: Shield, title: 'Security First', desc: 'Built-in security architecture protecting your systems and data from evolving threats.' },
          { icon: Zap, title: 'High Performance', desc: 'Optimized infrastructure ensuring consistent uptime and peak performance.' },
          { icon: Network, title: 'Scalable Design', desc: 'Solutions that grow with your business without constant rework or disruption.' },
        ].map(item => (
          <div style="padding: 2.5rem; border-radius: 20px; border: 1px solid var(--border); background: var(--navy-2); transition: all 0.3s ease; text-align: center;" class="hover-glow">
            <div style="width: 64px; height: 64px; background: var(--brand-blue-pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--brand-blue);">
              <item.icon size={32} />
            </div>
            <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--white);">{item.title}</h3>
            <p style="color: var(--white-dim); line-height: 1.6;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPREHENSIVE IT SERVICES (from v2) -->
  <section style="padding: 6rem 0; background: var(--navy-2);">
    <div class="container">
      <div class="section-header" style="text-align: center; margin-bottom: 4rem;">
        <h2 class="section-title">Comprehensive IT Services</h2>
        <p class="section-sub" style="margin: 1rem auto 0;">A complete range of infrastructure and managed services designed for modern businesses.</p>
      </div>
      
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px,1fr)); gap:2rem;">
        {[
          { icon: Cloud, title: 'Cloud Infrastructure', desc: 'Design, deploy, and optimize cloud environments across AWS, Azure, and hybrid solutions.' },
          { icon: Shield, title: 'Cybersecurity', desc: 'Comprehensive security framework implementation and management to protect your systems.' },
          { icon: Network, title: 'Network Optimization', desc: 'Build and maintain high-performing networks with monitoring and optimization.' },
          { icon: BarChart3, title: 'Managed IT Services', desc: 'Proactive monitoring, maintenance, and support for stable system operations.' },
          { icon: Zap, title: 'Disaster Recovery', desc: 'Ensure business continuity with robust backup and recovery systems.' },
          { icon: Users, title: 'Endpoint Management', desc: 'Secure and manage devices across your entire organization with ease.' },
        ].map(s => (
          <div class="card hover-lift" style="padding: 2.5rem; border: 1px solid var(--border); border-radius: 16px; background: var(--navy); transition: all 0.3s ease;">
            <div style="color: var(--brand-blue); margin-bottom: 1.5rem;"><s.icon size={32} /></div>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem; color: var(--white);">{s.title}</h3>
            <p style="color: var(--white-dim); font-size: 0.95rem; line-height: 1.6;">{s.desc}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:3.5rem;">
        <a href={`${base}/services`} class="btn-outline">Explore All Services <ArrowRight className="ml-2" size={18} /></a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="padding: 6rem 0; background: linear-gradient(180deg, transparent, var(--brand-blue-pale) 50%, transparent);">
    <div class="container">
      <div class="section-header">
        <span class="label">Our Approach</span>
        <h2 class="section-title" style="margin-top:0.75rem;">A structured process<br/>for measurable results</h2>
        <p class="section-sub">Nuvextro follows a proven methodology to ensure your infrastructure is resilient, efficient, and future-ready.</p>
      </div>
      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap:1.5rem;">
        {steps.map(s => (
          <div class="card" style="border-top: 2px solid var(--brand-blue); border-radius: 0 0 8px 8px; background: var(--navy);">
            <div class="step-num">Phase {s.n}</div>
            <div style="color:var(--brand-blue); margin-bottom:1rem;"><s.icon size={32} /></div>
            <div class="step-title">{s.title}</div>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION (v2 style) -->
  <section style="padding: 8rem 0; background: var(--navy); border-top: 1px solid var(--border);">
    <div class="container" style="text-align: center; max-width: 800px;">
      <h2 style="font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 800; color: var(--white); line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -0.02em;">
        Ready to Transform Your IT Infrastructure?
      </h2>
      <p style="color: var(--white-dim); font-size: 1.15rem; margin-bottom: 3rem; line-height: 1.6; max-width: 600px; margin-left: auto; margin-right: auto;">
        Let's discuss how Nuvextro can help you build reliable, scalable, and secure systems.
      </p>
      <div style="display:flex; gap:1.25rem; justify-content:center; flex-wrap:wrap;">
        <a href={`${base}/contact`} class="btn-primary" style="padding: 1rem 2.5rem; font-size: 1rem;">
          Schedule Consultation <ArrowRight className="ml-2" size={20} />
        </a>
        <a href={`${base}/case-studies`} class="btn-outline" style="padding: 1rem 2.5rem; font-size: 1rem; border-width: 2px; border-color: var(--brand-blue);">
          View Case Studies
        </a>
      </div>
    </div>
  </section>

</Base>
