---
import Base from '../layouts/Base.astro';
import { 
  Settings, Cloud, Blocks, Shield, Network, Code,
  CheckCircle2
} from 'lucide-astro';

const profiles = [
  { icon: Settings, title: 'VMware Specialists', desc: 'vSphere, vSAN, NSX-T certified engineers for virtualization projects.' },
  { icon: Cloud, title: 'Cloud Architects', desc: 'AWS, Azure, GCP certified professionals for cloud deployments and migrations.' },
  { icon: Blocks, title: 'Kubernetes Engineers', desc: 'Platform engineers with container orchestration and GitOps expertise.' },
  { icon: Shield, title: 'Security Specialists', desc: 'Cybersecurity professionals with CISSP, CISM, or equivalent certifications.' },
  { icon: Network, title: 'Network Engineers', desc: 'CCIE/CCNP-level engineers for enterprise network design and deployment.' },
  { icon: Code, title: 'DevOps & Automation', desc: 'Infrastructure automation, CI/CD, and IaC specialists (Terraform, Ansible).' },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Careers — Nuvextro" description="Join Nuvextro and work on cutting-edge IT infrastructure, cloud, and cybersecurity projects in a growth-focused environment.">

  <!-- HERO -->
  <section class="hero" style={`background-image: url('${base}/img/careers-hero-v4k.png'); background-size: cover; background-position: center; position: relative; padding: 10rem 0 6rem; min-height: auto;`}>
    <div class="hero-overlay" style="position: absolute; inset: 0; background: rgba(10, 25, 47, 0.4);"></div>
    <div class="container hero-content" style="position: relative; z-index: 1;">
      <div class="glass-box animate-fade-in" style="max-width: 800px;">
        <div class="hero-eyebrow animate delay-1">
          <span class="label" style="color: var(--brand-blue); border-color: rgba(27, 168, 250, 0.3); background: rgba(27, 168, 250, 0.05);">Work With Us</span>
        </div>
        <h1 class="hero-title animate delay-2" style="font-size: clamp(2.2rem, 5vw, 3.8rem); line-height: 1.1; color: #ffffff;">
          Build Your Career in<br/><span style="color:var(--brand-blue);">IT Infrastructure</span>
        </h1>
        <p class="hero-sub animate delay-3" style="color: rgba(255,255,255,0.9); max-width: 600px; margin-bottom: 0;">
          Nuvextro offers opportunities for experienced IT professionals to work on advanced infrastructure, cloud, and cybersecurity projects. Join a team focused on excellence and innovation.
        </p>
      </div>
    </div>
  </section>

  <section class="first-section" style="padding-bottom: 6rem;">
    <div class="container">

      <!-- WHY JOIN -->
      <div style="margin-bottom:5rem;">
        <div class="section-header">
          <span class="label">Why Join Nuvextro</span>
          <h2 class="section-title" style="margin-top:0.75rem;">A growth-focused environment</h2>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.5rem;">
          {[
            ['Enterprise Projects', 'Work on high-impact infrastructure transformations for global enterprise clients.'],
            ['Continuous Growth', 'Develop your skills with access to the latest technologies and expert-led knowledge sharing.'],
            ['Flexible & Dynamic', 'A modern work environment designed for professionals who value results and agility.'],
          ].map(([t,d]) => (
            <div class="card" style="display:flex; gap:1rem;">
              <CheckCircle2 size={24} class="cyan" style="flex-shrink:0; margin-top:2px;" />
              <div>
                <div style="font-weight:700; margin-bottom:0.3rem; font-size:0.95rem;">{t}</div>
                <p style="font-size:0.88rem; color:var(--white-dim); line-height:1.6;">{d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- PROFILES -->
      <div style="margin-bottom:5rem;">
        <div class="section-header">
          <span class="label">Our Expertise</span>
          <h2 class="section-title" style="margin-top:0.75rem;">Roles we're looking for</h2>
          <p class="section-sub">We are always looking for certified, experienced professionals across infrastructure and cloud disciplines.</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.25rem;">
          {profiles.map(p => (
            <div class="card">
              <div style="color:var(--brand-blue); margin-bottom:0.75rem;"><p.icon size={28} /></div>
              <div style="font-weight:700; margin-bottom:0.3rem;">{p.title}</div>
              <p style="font-size:0.88rem; color:var(--white-dim); line-height:1.6;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- INQUIRY FORM -->
      <div style="max-width:680px; margin:0 auto;">
        <div class="section-header">
          <span class="label">Apply Now</span>
          <h2 class="section-title" style="margin-top:0.75rem;">Join the team</h2>
          <p class="section-sub">Tell us about your expertise and we'll be in touch to discuss potential opportunities.</p>
        </div>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          id="partner-form"
          style="position:relative; z-index:1;"
        >
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="New Career Application — Nuvextro" />
          <input type="hidden" name="redirect" value="https://nuvextro.pages.dev/thank-you" />

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="form-group">
              <label class="form-label">Full Name *</label>
              <input type="text" name="name" class="form-input" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label class="form-label">Email *</label>
              <input type="email" name="email" class="form-input" required placeholder="your@email.com" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Primary Expertise *</label>
            <select name="expertise" class="form-select" required>
              <option value="" disabled selected>Select your specialization</option>
              <option>VMware / Virtualization</option>
              <option>Cloud Architecture (AWS / Azure / GCP)</option>
              <option>Kubernetes / Container Platforms</option>
              <option>Cybersecurity</option>
              <option>Network Engineering</option>
              <option>DevOps / Infrastructure Automation</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Certifications</label>
            <input type="text" name="certifications" class="form-input" placeholder="e.g. VMware VCP, AWS Solutions Architect, CISSP" />
          </div>
          <div class="form-group">
            <label class="form-label">Experience</label>
            <select name="experience" class="form-select">
              <option value="" disabled selected>Select range</option>
              <option>3–5 years</option>
              <option>5–8 years</option>
              <option>8–12 years</option>
              <option>12+ years</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Tell us about yourself *</label>
            <textarea name="message" class="form-textarea" required placeholder="Brief background, certifications, and why you want to join Nuvextro..."></textarea>
          </div>
          <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">
            Submit Application →
          </button>
        </form>
      </div>
    </div>
  </section>

</Base>
