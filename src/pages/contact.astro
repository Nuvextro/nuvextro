import Base from '../layouts/Base.astro';
import { CircleDot } from 'lucide-astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Contact — Nuvextro" description="Get in touch with Nuvextro for a free consultation on your enterprise infrastructure and cloud needs.">

  <!-- HERO -->
  <section class="hero" style={`background-image: url('${base}/img/contact-hero.png'); background-size: cover; background-position: center; position: relative; padding: 10rem 0 6rem; min-height: auto;`}>
    <div class="hero-overlay" style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(10, 25, 47, 0.8), rgba(10, 25, 47, 0.4));"></div>
    <div class="container hero-content" style="position: relative; z-index: 1;">
      <div class="hero-eyebrow animate delay-1">
        <span class="label" style="color: var(--brand-blue); border-color: var(--brand-blue-pale);">Get in Touch</span>
      </div>
      <h1 class="hero-title animate delay-2" style="font-size: clamp(2.2rem, 5vw, 3.8rem); line-height: 1.1; color: #ffffff;">
        Let's talk about<br/>your infrastructure
      </h1>
      <p class="hero-sub animate delay-3" style="color: rgba(255,255,255,0.9); max-width: 600px;">
        Whether you have a specific project, an ongoing need, or just want to explore what's possible — we're happy to have a no-obligation conversation.
      </p>
    </div>
  </section>

  <section style="padding:0 0 6rem;">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT -->
        <div>
          <div style="margin-bottom:2.5rem;">
            <span class="label">Response time</span>
            <p style="font-size:0.95rem; color:var(--white-dim); margin-top:0.5rem; line-height:1.7;">We typically respond within <strong style="color:var(--white);">1–2 business days</strong>. For urgent infrastructure needs, please mention that in your message.</p>
          </div>
          <div style="display:flex; flex-direction:column; gap:1rem; margin-bottom:2.5rem;">
            {[
              { label: 'Managed Services', desc: 'Ongoing IT, cloud, network, or security management' },
              { label: 'Implementation Project', desc: 'VMware, cloud migration, DR, security or network deployment' },
              { label: 'Advisory Retainer', desc: 'Infrastructure architecture guidance and consultation' },
              { label: 'Careers', desc: 'Join the Nuvextro team as an infrastructure expert' },
            ].map(item => (
              <div class="highlight-box" style="display:flex; gap:0.75rem;">
                <CircleDot size={18} style="color:var(--brand-blue); margin-top:2px; flex-shrink:0;" />
                <div>
                  <div style="font-weight:700; font-size:0.9rem;">{item.label}</div>
                  <div style="font-size:0.82rem; color:var(--white-dim); margin-top:0.1rem;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
          <div style="border-top:1px solid var(--border); padding-top:2rem;">
            <div style="font-size:0.75rem; font-family:'Open Sans', sans-serif; letter-spacing:0.1em; color:var(--white-muted); text-transform:uppercase; margin-bottom:0.5rem;">Email</div>
            <a href="mailto:hello@nuvextro.com" style="color:var(--brand-blue); font-size:0.95rem; text-decoration:none;">hello@nuvextro.com</a>
          </div>
        </div>

        <!-- FORM -->
        <div>
          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
            <input type="hidden" name="subject" value="New Enquiry — Nuvextro" />
            <input type="hidden" name="redirect" value="https://nuvextro.pages.dev/thank-you" />
            <!-- honeypot -->
            <input type="checkbox" name="botcheck" style="display:none;" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div class="form-group">
                <label class="form-label">Full Name *</label>
                <input type="text" name="name" class="form-input" required placeholder="Jane Smith" />
              </div>
              <div class="form-group">
                <label class="form-label">Email Address *</label>
                <input type="email" name="email" class="form-input" required placeholder="jane@company.com" />
              </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div class="form-group">
                <label class="form-label">Company</label>
                <input type="text" name="company" class="form-input" placeholder="Your organization" />
              </div>
              <div class="form-group">
                <label class="form-label">Phone</label>
                <input type="tel" name="phone" class="form-input" placeholder="+1 (555) 000-0000" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Services Required *</label>
              <select name="service" class="form-select" required>
                <option value="" disabled selected>Select a service area</option>
                <option>Cloud Architecture</option>
                <option>Cybersecurity</option>
                <option>AI & Data Science</option>
                <option>Digital Transformation</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Tell us about your needs *</label>
              <textarea
                name="message"
                class="form-textarea"
                required
                style="min-height:140px;"
                placeholder="Describe your infrastructure environment, current challenges, or project requirements. The more context you share, the better prepared we'll be for our conversation."
              ></textarea>
            </div>

            <div class="form-group" style="display:flex; align-items:flex-start; gap:0.75rem;">
              <input type="checkbox" name="consent" id="consent" required style="margin-top:3px; accent-color:var(--brand-blue); width:16px; height:16px; flex-shrink:0;" />
              <label for="consent" style="font-size:0.82rem; color:var(--white-dim); line-height:1.5; cursor:pointer;">
                I consent to Nuvextro storing my contact details to respond to this inquiry. We do not share your information with third parties.
              </label>
            </div>

            <button type="submit" class="btn-primary" style="width:100%; justify-content:center; font-size:0.95rem; padding:0.9rem 2rem;">
              Send Message →
            </button>

            <p id="form-status" style="display:none; text-align:center; margin-top:1rem; font-size:0.88rem;"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('form-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'Sending…';
      btn.disabled = true;

      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: data });
      const json = await res.json();

      if (json.success) {
        form.innerHTML = `
          <div style="text-align:center; padding:3rem; border:1px solid var(--border-hi); border-radius:8px; background:var(--brand-blue-pale);">
            <div style="font-size:2rem; margin-bottom:1rem;">✓</div>
            <h3 style="font-size:1.2rem; font-weight:700; margin-bottom:0.5rem;">Message received</h3>
            <p style="color:var(--white-dim); font-size:0.9rem;">We'll be in touch within 1–2 business days.</p>
          </div>`;
      } else {
        if (status) {
          status.style.display = 'block';
          status.style.color = '#ff6b6b';
          status.textContent = 'Something went wrong. Please try again or email us directly.';
        }
        btn.textContent = 'Send Message →';
        btn.disabled = false;
      }
    });
  </script>

  <style>
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      align-items: start;
    }
    @media (min-width: 769px) {
      .contact-grid {
        grid-template-columns: 1fr 1.5fr;
        gap: 5rem;
      }
    }
  </style>
</Base>
