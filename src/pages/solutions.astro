---
import Base from '../layouts/Base.astro';
import { 
  Settings, Cloud, RefreshCw, Shield, Network,
  Blocks, Box, Bot, Laptop, Check, Globe, ShieldCheck
} from 'lucide-astro';

const solutions = [
  {
    id: 'vmware',
    icon: Settings,
    label: 'Virtualization',
    title: 'VMware vSphere Cluster Deployment',
    desc: 'End-to-end deployment of VMware vSphere infrastructure — from initial architecture design through implementation, configuration, and handover.',
    scope: [
      'Infrastructure assessment and architecture design',
      'ESXi host installation and cluster configuration',
      'vCenter Server deployment and configuration',
      'Storage integration (SAN/NAS/vSAN)',
      'Network configuration (vDS, NSX-T optionally)',
      'HA, DRS, and vMotion configuration',
      'Documentation and knowledge transfer',
    ],
    price: '$4,000 – $8,000',
    duration: '2 – 4 weeks',
  },
  {
    id: 'cloud-migration',
    icon: Cloud,
    label: 'Cloud',
    title: 'Cloud Migration & Deployment',
    desc: 'Assessment, planning, and execution of workload migrations to AWS, Azure, or GCP — with minimal disruption and maximum optimization.',
    scope: [
      'Workload discovery and migration assessment',
      'Target architecture design and sizing',
      'Migration wave planning and execution',
      'Landing zone and governance configuration',
      'Cost optimization post-migration',
      'Cutover planning and execution support',
      'Post-migration monitoring and tuning',
    ],
    price: '$6,000 – $18,000',
    duration: '4 – 12 weeks',
  },
  {
    id: 'dr',
    icon: RefreshCw,
    label: 'Disaster Recovery',
    title: 'Disaster Recovery Architecture & Implementation',
    desc: 'Design and implementation of enterprise disaster recovery solutions with defined RPO/RTO targets and tested runbooks.',
    scope: [
      'Business impact analysis and RTO/RPO definition',
      'DR architecture design (on-prem, cloud, or hybrid)',
      'Replication setup (Veeam, Zerto, Azure Site Recovery)',
      'DR site configuration and validation',
      'Runbook development and tabletop testing',
      'Scheduled DR tests and documentation',
      'Ongoing DR maintenance and review',
    ],
    price: '$5,000 – $15,000',
    duration: '3 – 8 weeks',
  },
  {
    id: 'security',
    icon: Shield,
    label: 'Security',
    title: 'Security Infrastructure Deployment',
    desc: 'Design and deployment of enterprise security infrastructure — from perimeter firewalls to endpoint protection and SIEM solutions.',
    scope: [
      'Security architecture assessment and design',
      'Next-generation firewall deployment and configuration',
      'Endpoint detection and response (EDR) rollout',
      'SIEM platform deployment and tuning',
      'Privileged access management (PAM) setup',
      'Security baseline hardening across systems',
      'Incident response runbook development',
    ],
    price: '$5,000 – $12,000',
    duration: '3 – 6 weeks',
  },
  {
    id: 'network',
    icon: Network,
    label: 'Network',
    title: 'Network Infrastructure Deployment',
    desc: 'Design, procurement support, and deployment of enterprise network infrastructure — LAN, WAN, and SD-WAN environments.',
    scope: [
      'Network architecture design and documentation',
      'Core, distribution, and access layer configuration',
      'Firewall and security policy implementation',
      'WAN/SD-WAN design and deployment',
      'VLAN, QoS, and routing configuration',
      'Network monitoring tooling setup',
      'Handover documentation and training',
    ],
    price: '$4,000 – $10,000',
    duration: '2 – 5 weeks',
  },
];

const future = [
  { icon: Blocks, title: 'Kubernetes Platforms', desc: 'Enterprise Kubernetes cluster deployment, GitOps pipelines, and platform engineering.' },
  { icon: Box, title: 'Container Infrastructure', desc: 'Container strategy, registry setup, and CI/CD pipeline design for containerized workloads.' },
  { icon: Bot, title: 'AI Infrastructure Solutions', desc: 'GPU cluster setup, LLM inference infrastructure, and enterprise AI platform deployments.' },
  { icon: Laptop, title: 'Enterprise Software Development', desc: 'Custom tooling, automation platforms, and internal developer platforms.' },
];
---

<Base title="Solutions — Nuvextro" description="Project-based infrastructure implementation solutions including VMware, cloud migration, disaster recovery, and security deployments.">

  <div class="page-hero">
    <div class="page-hero-glow"></div>
    <div class="container">
      <span class="label">Implementation Projects</span>
      <h1 style="font-size:clamp(2.2rem,5vw,3.8rem); font-weight:800; letter-spacing:-0.03em; margin:0.75rem 0 1rem;">
        Project-based solutions.<br/>Delivered end-to-end.
      </h1>
      <p style="color:var(--white-dim); font-size:1.05rem; max-width:560px; line-height:1.7;">
        One-time or phased implementation projects, delivered by certified specialists with full governance, documentation, and knowledge transfer.
      </p>
    </div>
  </div>

  <section style="padding:0 0 6rem;">
    <div class="container">
      <div style="display:flex; flex-direction:column; gap:2rem;">
        {solutions.map(s => (
          <div id={s.id} class="card">
            <div class="solution-header-grid">
              <div style="display:flex; align-items:center; gap:1rem;">
                <div class="service-icon" style="margin-bottom:0;"><s.icon size={24} /></div>
                <div>
                  <div class="label" style="margin-bottom:0.2rem;">{s.label}</div>
                  <h2 style="font-size:1.25rem; font-weight:700;">{s.title}</h2>
                </div>
              </div>
            </div>
            <p style="color:var(--white-dim); font-size:0.92rem; line-height:1.7; margin-bottom:1.5rem;">{s.desc}</p>
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap:0.5rem; margin-bottom:1.5rem;">
              {s.scope.map(item => (
                <div style="display:flex; gap:0.6rem; align-items:flex-start; font-size:0.85rem; color:var(--white-dim);">
                  <Check size={14} class="cyan" style="flex-shrink:0; margin-top:2px;" />
                  {item}
                </div>
              ))}
            </div>
            <div style="display:flex; gap:1rem; align-items:center;">
              <a href="/contact" class="btn-primary" style="font-size:0.82rem; padding:0.55rem 1.2rem;">Request a Quote →</a>
            </div>
          </div>
        ))}
      </div>

      <!-- Future Roadmap -->
      <div style="margin-top:5rem;">
        <div class="section-header">
          <span class="label">Coming Soon</span>
          <h2 class="section-title" style="margin-top:0.75rem;">Future Expansion Areas</h2>
          <p class="section-sub">Nuvextro is continuously expanding its capabilities in these high-demand technology sectors.</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.5rem;">
          {future.map(f => (
            <div class="card" style="opacity:0.7; border-style:dashed;">
              <div style="color:var(--brand-blue); margin-bottom:0.75rem;"><f.icon size={28} /></div>
              <div style="font-weight:700; margin-bottom:0.4rem;">{f.title}</div>
              <p style="font-size:0.88rem; color:var(--white-dim); line-height:1.6;">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <style>
    .solution-header-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .solution-meta {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      align-items: center;
    }
    @media (min-width: 640px) {
      .solution-header-grid {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: start;
      }
      .solution-meta {
        flex-direction: column;
        align-items: flex-end;
        text-align: right;
        gap: 0.4rem;
      }
    }
  </style>
</Base>
