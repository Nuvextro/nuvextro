---
import '../styles/global.css';
import { Sun, Moon, Monitor } from 'lucide-astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = 'Nuvextro — Engineering Technology for Tomorrow',
  description = 'Nuvextro is a specialized enterprise infrastructure and cloud consulting firm. Engineering Technology for Tomorrow through a dedicated team of expert professionals.',
  path = '',
} = Astro.props;

const navLinks = [
  { href: '/',              label: 'Home' },
  { href: '/services',      label: 'Services' },
  { href: '/solutions',     label: 'Solutions' },
  { href: '/case-studies',  label: 'Case Studies' },
  { href: '/about',         label: 'About' },
  { href: '/careers',       label: 'Careers' },
  { href: '/contact',       label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/img/logo/logo-square.png" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        <img src="/img/logo/logo-transparentbg.png" alt="Nuvextro Logo" class="brand-logo" />
      </a>
      <ul class="nav-links" id="nav-links">
        {navLinks.map(l => (
          <li>
            <a
              href={l.href}
              class={currentPath === l.href.replace(/\/$/, '') || (l.href !== '/' && currentPath.startsWith(l.href)) ? 'active' : ''}
            >{l.label}</a>
          </li>
        ))}
        <li><a href="/contact" class="btn-primary" style="padding:0.55rem 1.2rem;font-size:0.8rem;">Get in Touch</a></li>
        <li class="theme-toggle-container">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <Sun class="icon-sun" size={18} />
            <Moon class="icon-moon" size={18} />
            <Monitor class="icon-system" size={18} />
          </button>
        </li>
      </ul>
      <button class="nav-burger" id="burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">
            <img src="/img/logo/logo-transparentbg.png" alt="Nuvextro Logo" class="brand-logo" />
          </div>
          <p class="footer-tagline" style="margin-top: 0.5rem;">Engineering Technology for Tomorrow</p>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Services</div>
          <a href="/services#managed-it">Managed IT</a>
          <a href="/services#cloud">Cloud Management</a>
          <a href="/services#network">Network Monitoring</a>
          <a href="/services#security">Cybersecurity</a>
          <a href="/services#backup">Backup & DR</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Company</div>
          <a href="/about">About</a>
          <a href="/case-studies">Case Studies</a>
          <a href="/careers">Careers</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Solutions</div>
          <a href="/solutions#vmware">VMware Deployment</a>
          <a href="/solutions#cloud-migration">Cloud Migration</a>
          <a href="/solutions#dr">Disaster Recovery</a>
          <a href="/solutions#security">Security Infra</a>
          <a href="/solutions#network">Network Infra</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 Nuvextro. All rights reserved.</span>
        <span>Engineering Technology for Tomorrow</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    const getTheme = () => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return 'light';
    };

    const setTheme = (theme) => {
      const root = document.documentElement;
      if (theme === 'system') {
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        root.setAttribute('data-theme', systemTheme);
      } else {
        root.setAttribute('data-theme', theme);
      }
      localStorage.setItem('theme', theme);
    };

    const currentTheme = getTheme();
    setTheme(currentTheme);

    document.addEventListener('astro:after-swap', () => {
      setTheme(getTheme());
    });
  </script>

  <style>
    .theme-toggle {
      background: none;
      border: 1px solid var(--border);
      color: var(--white-dim);
      cursor: pointer;
      padding: 0.5rem;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .theme-toggle:hover {
      color: var(--white);
      border-color: var(--border-hi);
      background: var(--brand-blue-pale);
    }
    
    .icon-sun, .icon-moon, .icon-system { display: none; }
    :root[data-theme="light"] .icon-sun { display: block; }
    :root[data-theme="dark"] .icon-moon { display: block; }
    /* We could add logic for 'system' icon if we want a 3-way toggle, 
       but for now we'll do a simple dark/light toggle and can expand to system if needed.
       Actually, I'll implement a cycle: light -> dark -> system.
    */
  </style>

  <script>
    const burger = document.getElementById('burger');
    const links = document.getElementById('nav-links');
    burger?.addEventListener('click', () => links?.classList.toggle('open'));

    const toggleBtn = document.getElementById('theme-toggle');
    toggleBtn?.addEventListener('click', () => {
      const root = document.documentElement;
      const current = localStorage.getItem('theme') || 'system';
      let next = 'light';
      if (current === 'light') next = 'dark';
      else if (current === 'dark') next = 'system';
      
      // Dispatch custom event or just call function if defined
      const setTheme = (theme) => {
        if (theme === 'system') {
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          root.setAttribute('data-theme', systemTheme);
        } else {
          root.setAttribute('data-theme', theme);
        }
        localStorage.setItem('theme', theme);
      };
      setTheme(next);
      
      // Update icon visibility based on the *choice*
      updateIcon(next);
    });

    function updateIcon(theme) {
      const sun = document.querySelector('.icon-sun');
      const moon = document.querySelector('.icon-moon');
      const sys = document.querySelector('.icon-system');
      if (!sun || !moon || !sys) return;
      
      sun.style.display = theme === 'light' ? 'block' : 'none';
      moon.style.display = theme === 'dark' ? 'block' : 'none';
      sys.style.display = theme === 'system' ? 'block' : 'none';
    }
    
    // Initial icon state
    updateIcon(localStorage.getItem('theme') || 'system');
  </script>
</body>
</html>
