---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = 'Nuvextro — Engineering Technology for Tomorrow',
  description = 'Nuvextro is a specialized enterprise infrastructure and cloud consulting firm. Engineering Technology for Tomorrow through a dedicated team of expert professionals.',
  path = '',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`,              label: 'Home' },
  { href: `${base}/services`,      label: 'Services' },
  { href: `${base}/solutions`,     label: 'Solutions' },
  { href: `${base}/case-studies`,  label: 'Case Studies' },
  { href: `${base}/about`,         label: 'About' },
  { href: `${base}/careers`,       label: 'Careers' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href={`${base}/img/logo/logo-square.png`} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  
  <!-- Google Translate -->
  <script is:inline>
    function googleTranslateElementInit() {
      new google.translate.TranslateElement({
        pageLanguage: 'en',
        includedLanguages: 'en,fr,de,ar,ja,zh-CN,ko',
        layout: google.translate.TranslateElement.InlineLayout.SIMPLE
      }, 'google_translate_element');
    }
  </script>
  <script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  
  <style is:inline>
    .goog-te-banner-frame.skiptranslate { display: none !important; }
    body { top: 0px !important; }
    .goog-te-gadget-icon { display: none !important; }
    .goog-te-gadget-simple {
      background-color: transparent !important;
      border: 1px solid var(--border) !important;
      padding: 4px 8px !important;
      border-radius: 4px !important;
      font-size: 13px !important;
      color: var(--white-dim) !important;
    }
    .goog-te-menu-value span { color: var(--white-dim) !important; }
    
    /* Fix translate dropdown height and positioning */
    .goog-te-menu-frame {
      max-height: 400px !important;
      overflow-y: auto !important;
      box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
      border: 1px solid var(--border) !important;
      border-radius: 8px !important;
    }
    .goog-te-menu2 {
      max-height: 400px !important;
      overflow-y: auto !important;
      background-color: var(--navy-2) !important;
      border: none !important;
    }
    .goog-te-menu2-item div, .goog-te-menu2-item:link div, .goog-te-menu2-item:visited div {
      color: var(--white) !important;
      font-family: 'Open Sans', sans-serif !important;
    }
    .goog-te-menu2-item:hover div {
      background-color: var(--brand-blue-pale) !important;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href={`${base}/`} class="nav-logo" style="margin-right: auto;">
        <img src={`${base}/img/logo/logo-nuvextro.webp`} alt="Nuvextro Logo" class="brand-logo" style="height: 56px; width: auto;" />
      </a>
      <ul class="nav-links" id="nav-links">
        {navLinks.map(l => (
          <li>
            <a
              href={l.href}
              class={currentPath === l.href.replace(/\/$/, '') || (l.href !== '/' && currentPath.startsWith(l.href)) ? 'active' : ''}
              style="white-space: nowrap;"
            >{l.label}</a>
          </li>
        ))}
        <li><a href={`${base}/contact`} class="btn-primary" style="padding:0.55rem 1.2rem;font-size:0.8rem;">Request a Quote</a></li>
        <li class="translate-container">
          <div id="google_translate_element"></div>
        </li>
      </ul>
      <button class="nav-burger" id="burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">
            <img src={`${base}/img/logo/logo-nuvextro.webp`} alt="Nuvextro Logo" class="brand-logo" style="height: 64px; width: auto;" />
          </div>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Services</div>
          <a href={`${base}/services#managed-it`}>Managed IT</a>
          <a href={`${base}/services#cloud`}>Cloud Management</a>
          <a href={`${base}/services#network`}>Network Monitoring</a>
          <a href={`${base}/services#security`}>Cybersecurity</a>
          <a href={`${base}/services#backup`}>Backup & DR</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Company</div>
          <a href={`${base}/about`}>About</a>
          <a href={`${base}/case-studies`}>Case Studies</a>
          <a href={`${base}/careers`}>Careers</a>
          <a href={`${base}/contact`}>Contact</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Solutions</div>
          <a href={`${base}/solutions#vmware`}>VMware Deployment</a>
          <a href={`${base}/solutions#cloud-migration`}>Cloud Migration</a>
          <a href={`${base}/solutions#dr`}>Disaster Recovery</a>
          <a href={`${base}/solutions#security`}>Security Infra</a>
          <a href={`${base}/solutions#network`}>Network Infra</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 Nuvextro. All rights reserved.</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Theme script removed as per request to stick to light mode
  </script>

  <style>
    .translate-container {
      display: flex;
      align-items: center;
      margin-left: 0.5rem;
    }
  </style>

  <script>
    const burger = document.getElementById('burger');
    const links = document.getElementById('nav-links');
    burger?.addEventListener('click', () => links?.classList.toggle('open'));
  </script>
</body>
</html>
